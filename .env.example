# JWT Security (64+ символа, криптографически стойкий)
JWT_SECRET=замените_на_случайную_строку_64+_символа_используйте_openssl_rand_base64_48

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=15433
DB_NAME=check_rf
DB_USER=check_user
DB_PASSWORD=замените_на_случайный_пароль_16+_символов

# Redis
REDIS_HOST=redis
REDIS_PORT=16380
REDIS_PASSWORD=замените_на_случайный_пароль_16+_символов

# Сервисы (порты для internal сети)
AUTH_SERVICE_PORT=18273
USER_SERVICE_PORT=19384
MCO_SERVICE_PORT=17456
ADMIN_SERVICE_PORT=16542

# MCO API Token
MCO_API_TOKEN=замените_на_реальный_токен_ФНС

# Telegram Bot (для отправки кодов авторизации)
TELEGRAM_BOT_TOKEN=ваш_токен_бота  # Добавить в GitHub Secrets: TELEGRAM_BOT_TOKEN

# SmartCaptcha
SMARTCAPTCHA_SERVER_KEY=замените_на_реальный_ключ_Yandex

# Docker сети
INTERNAL_NETWORK=check24_internal
